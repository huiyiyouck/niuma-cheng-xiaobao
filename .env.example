DATABASE_URL=
DB_SSL_VERIFY=true
ADMIN_TOKEN=
ADMIN_REQUIRE_BOTH=false
ADMIN_ALLOWED_IPS=127.0.0.1
CORS_ALLOW_ORIGINS=*
TRUST_PROXY_HEADERS=false
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
TASK_STALE_SECONDS=600
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_SECONDS=1.0

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

WORKER_ID=worker-1
SCHEDULER_SCAN_SECONDS=5
FETCH_CONCURRENCY=2
PROCESS_CONCURRENCY=1

DEFAULT_FETCH_EVERY_SECONDS=600
DEFAULT_MAX_ITEMS_PER_RUN=20
DEFAULT_FAIL_ALERT_THRESHOLD=5
DEFAULT_ZERO_NEW_HOURS=24

# PostgreSQL (docker-compose 本地开发用)
POSTGRES_USER=news
POSTGRES_PASSWORD=news
POSTGRES_DB=news
POSTGRES_PORT=5432

# X/Twitter API (optional)
X_BEARER_TOKEN=
