[Unit]
Description=News Aggregator API
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/news-aggregator
EnvironmentFile=/opt/news-aggregator/.env
ExecStart=/opt/news-aggregator/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

